{
  "name": "gifmayker",
  "version": "0.1.41",
  "private": true,
  "description": "Make-your-own GIF tool — capture, trim, GIF, soundboard (desktop, Electron)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "SMOKE_TEST=1 electron .",
    "icon": "node genicon.js",
    "appicon": "node genappicon.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "com.jovankirovski.gifmayker",
    "productName": "GifMayker",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "src/fonts/Anton-Regular.ttf"
    ],
    "afterPack": "./build/afterPack.js",
    "files": [
      "electron/**",
      "src/**",
      "assets/**",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "identity": null,
      "extendInfo": {
        "NSCameraUsageDescription": "GifMayker records your webcam when you choose it as a capture source."
      },
      "artifactName": "GifMayker-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ],
      "artifactName": "GifMayker-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
